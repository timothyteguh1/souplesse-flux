{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": ["laravel", "framework"],
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "asantibanez/livewire-charts": "^4.1",
        "barryvdh/laravel-snappy": "^1.0",
        "codedge/laravel-fpdf": "^1.12",
        "danharrin/livewire-rate-limiting": "*",
        "h4cc/wkhtmltoimage-amd64": "^0.12.4",
        "h4cc/wkhtmltopdf-amd64": "^0.12.4",
        "kirschbaum-development/eloquent-power-joins": "^3.5",
        "lab404/laravel-impersonate": "*",
        "laravel/framework": "^11.0",
        "laravel/horizon": "^5.24",
        "laravel/pail": "^1.2",
        "laravel/pulse": "^1.0",
        "laravel/telescope": "^5.0",
        "laravel/tinker": "^2.9",
        "livewire/livewire": "^3.3",
        "maatwebsite/excel": "^3.1",
        "milon/barcode": "^11.0",
        "opcodesio/log-viewer": "^3.4",
        "saloonphp/laravel-plugin": "^3.0",
        "saloonphp/saloon": "^3.0",
        "sentry/sentry-laravel": "^4.3",
        "spatie/browsershot": "^4.3",
        "spatie/laravel-activitylog": "^4.8",
        "spatie/laravel-backup": "^8.6",
        "spatie/laravel-deleted-models": "^1.0",
        "spatie/laravel-medialibrary": "^11.3",
        "spatie/laravel-permission": "^6.7",
        "spatie/laravel-ray": "^1.35",
        "staudenmeir/laravel-adjacency-list": "^1.21",
        "wnx/laravel-backup-restore": "^1.3"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^3.13",
        "fakerphp/faker": "^1.23",
        "larastan/larastan": "^2.9",
        "laravel/pint": "^1.13",
        "laravel/sail": "^1.26",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.0",
        "pestphp/pest": "^3.2",
        "pestphp/pest-plugin-laravel": "^3.0",
        "pestphp/pest-plugin-livewire": "^3.0",
        "pestphp/pest-plugin-stressless": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "app/Utilities/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
            "@php artisan log-viewer:publish"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite"
        ],
        "pint": [
            "./vendor/bin/pint"
        ],
        "analyse": [
            "./vendor/bin/phpstan analyse"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true,
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
